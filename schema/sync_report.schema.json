{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Sync Report",
  "description": "Aggregate statistics for a single sync run.",
  "type": "object",
  "required": [
    "total_entities",
    "entities_synced",
    "entities_deleted",
    "total_conflicts",
    "conflicts_resolved_local",
    "conflicts_resolved_remote",
    "local_events_processed",
    "remote_events_processed",
    "duplicate_events_dropped",
    "entities_with_conflicts"
  ],
  "additionalProperties": true,
  "properties": {
    "total_entities":           { "type": "integer", "minimum": 0 },
    "entities_synced":          { "type": "integer", "minimum": 0 },
    "entities_deleted":         { "type": "integer", "minimum": 0 },
    "total_conflicts":          { "type": "integer", "minimum": 0 },
    "conflicts_resolved_local": { "type": "integer", "minimum": 0 },
    "conflicts_resolved_remote":{ "type": "integer", "minimum": 0 },
    "local_events_processed":   { "type": "integer", "minimum": 0 },
    "remote_events_processed":  { "type": "integer", "minimum": 0 },
    "duplicate_events_dropped": { "type": "integer", "minimum": 0 },
    "entities_with_conflicts":  { "type": "integer", "minimum": 0 }
  }
}
