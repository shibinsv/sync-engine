{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Sync Conflicts",
  "description": "One record per (entity_id, field) pair that had events from both sources.",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "entity_id", "field",
      "local_value", "remote_value",
      "local_timestamp", "remote_timestamp",
      "resolution", "resolution_reason"
    ],
    "additionalProperties": false,
    "properties": {
      "entity_id":          { "type": "string" },
      "field":              { "type": "string" },
      "local_value":        { "type": "string" },
      "remote_value":       { "type": "string" },
      "local_timestamp":    { "type": "string", "description": "ISO 8601 UTC" },
      "remote_timestamp":   { "type": "string", "description": "ISO 8601 UTC" },
      "resolution": {
        "type": "string",
        "enum": ["local_wins", "remote_wins"]
      },
      "resolution_reason":  { "type": "string" }
    }
  }
}
